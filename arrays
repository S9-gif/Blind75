'''arrays1 Contains Duplicate'''




class Solution:
    def hasDuplicate(self, nums):
        
        seen=set()
    
        for i in nums:
          if i in seen:
                return True 
          seen.add(i)
        else:
            return False  
        

 
solution=Solution()

print(solution.hasDuplicate([1,2,3,4]))

